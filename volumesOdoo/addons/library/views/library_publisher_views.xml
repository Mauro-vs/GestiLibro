<odoo>
  <record id="view_library_publisher_list" model="ir.ui.view">
    <field name="name">library.publisher.list</field>
    <field name="model">library.publisher</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="country"/>
      </list>
    </field>
  </record>

  <record id="view_library_publisher_form" model="ir.ui.view">
    <field name="name">library.publisher.form</field>
    <field name="model">library.publisher</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="country"/>
            <field name="website"/>
          </group>
          <group>
            <field name="book_ids"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_library_publisher" model="ir.actions.act_window">
    <field name="name">Editoriales</field>
    <field name="res_model">library.publisher</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
