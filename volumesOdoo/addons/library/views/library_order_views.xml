<odoo>
  <record id="view_library_order_tree" model="ir.ui.view">
    <field name="name">library.order.tree</field>
    <field name="model">library.order</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="client_id"/>
        <field name="date"/>
        <field name="state"/>
        <field name="amount_total"/>
      </list>
    </field>
  </record>

  <record id="view_library_order_form" model="ir.ui.view">
    <field name="name">library.order.form</field>
    <field name="model">library.order</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="client_id"/>
            <field name="date"/>
            <field name="state" readonly="1"/>
            <field name="currency_id"/>
            <field name="amount_total" readonly="1"/>
          </group>
          <notebook>
            <page string="Líneas de pedido">
              <field name="line_ids">
                <list editable="bottom">
                  <field name="book_id"/>
                  <field name="quantity"/>
                  <field name="unit_price"/>
                  <field name="price_subtotal" readonly="1"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_library_order" model="ir.actions.act_window">
    <field name="name">Pedidos</field>
    <field name="res_model">library.order</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
  
