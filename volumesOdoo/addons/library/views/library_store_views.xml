<odoo>
  <record id="view_library_store_list" model="ir.ui.view">
    <field name="name">library.store.list</field>
    <field name="model">library.store</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="address"/>
        <field name="responsible_id"/>
      </list>
    </field>
  </record>

  <record id="view_library_store_form" model="ir.ui.view">
    <field name="name">library.store.form</field>
    <field name="model">library.store</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="address"/>
            <field name="responsible_id"/>
          </group>
          <notebook>
            <page string="Stock">
              <field name="stock_ids">
                <list editable="bottom">
                  <field name="book_id"/>
                  <field name="quantity"/>
                  <field name="quantity_minimum"/>
                </list>
              </field>
            </page>
            <page string="Ventas">
              <field name="order_ids" readonly="1">
                <list>
                  <field name="name"/>
                  <field name="date"/>
                  <field name="client_id"/>
                  <field name="state"/>
                  <field name="amount_total"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_library_store" model="ir.actions.act_window">
    <field name="name">Tiendas</field>
    <field name="res_model">library.store</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
