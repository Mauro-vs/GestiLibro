<odoo>
  <record id="view_library_store_tree" model="ir.ui.view">
    <field name="name">library.store.tree</field>
    <field name="model">library.store</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
          <field name="address"/>
          <field name="responsible_id"/>
      </list>
    </field>
  </record>

  <record id="view_library_store_form" model="ir.ui.view">
    <field name="name">library.store.form</field>
    <field name="model">library.store</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="address"/>
            <field name="responsible_id"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_library_store" model="ir.actions.act_window">
    <field name="name">Tiendas</field>
    <field name="res_model">library.store</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
