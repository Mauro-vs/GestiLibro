<odoo>
  <!-- Grupos mínimos para asignar permisos desde ir.model.access.csv -->
  <record id="group_library_user" model="res.groups">
    <field name="name">Usuario Tienda de Libros</field>
    <field name="category_id" ref="base.module_category_hidden"/>
  </record>

  <record id="group_library_manager" model="res.groups">
    <field name="name">Gestor Tienda de Libros</field>
    <field name="category_id" ref="base.module_category_hidden"/>
    <field name="implied_ids" eval="[(4, ref('group_library_user'))]"/>
  </record>

  <!-- Asignación automática para que el menú sea visible sin configurar usuarios a mano -->
  <record id="base.group_user" model="res.groups">
    <field name="implied_ids" eval="[(4, ref('group_library_user'))]"/>
  </record>

  <record id="base.group_system" model="res.groups">
    <field name="implied_ids" eval="[(4, ref('group_library_manager'))]"/>
  </record>
</odoo>
